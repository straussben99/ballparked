{
  "expo": {
    "name": "BallParked",
    "slug": "ballparked",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ballparked",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ballparked.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "BallParked uses your location to show nearby stadiums on the map.",
        "NSPhotoLibraryUsageDescription": "BallParked needs access to your photos to add pictures to your stadium ratings.",
        "NSCameraUsageDescription": "BallParked uses your camera to take photos of stadiums.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF8F0",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFF8F0",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF6B5B"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "supabaseUrl": "https://qsodeogjotqjdevkrogt.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFzb2Rlb2dqb3RxamRldmtyb2d0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUxNDQzMzIsImV4cCI6MjA5MDcyMDMzMn0.RBZ74r5bsAV7DagD134Kv1RTqe6taZk1tlit9etBzww",
      "router": {},
      "eas": {
        "projectId": "5b9662b2-e6fe-4544-ae56-d3acb9e93e6b"
      }
    }
  }
}
